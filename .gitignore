################################################################################
# General .NET / Visual Studio
################################################################################

# Carpetas de salida y compilación
[Bb]in/
[Oo]bj/
out/

# Visual Studio (archivos de usuario y temporales)
.vs/
*.user
*.userosscache
*.sln.docstates

# Visual Studio Code
.vscode/
!.vscode/settings.json
!.vscode/tasks.json
!.vscode/launch.json
!.vscode/extensions.json

################################################################################
# Manejo de Dependencias
################################################################################

# NuGet Packages
*.nupkg
# Se recomienda NO subir la carpeta de paquetes
**/packages/*
!**/packages/build/

# Node.js (Si tienes algún cliente web o herramientas de build en JS)
node_modules/
npm-debug.log*

################################################################################
# Seguridad y Configuración Local
################################################################################

# Secretos de usuario (ASP.NET Core)
secrets.json

# Archivos de configuración de entorno (Locales)
appsettings.Development.json
appsettings.Local.json

# Logs y bases de datos locales
*.log
*.sqlite
*.db

################################################################################
# Herramientas y OS
################################################################################

# MacOS
.DS_Store

# Windows
Thumbs.db
ehthumbs.db

# Rider / JetBrains
.idea/

# Herramientas de cobertura de código
TestResults/
*.opencover.xml